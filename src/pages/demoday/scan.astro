---
import AppLayout from '../../layouts/AppLayout.astro';
import '../../styles/demoday.css';
---

<AppLayout title="Demo Day" hideHeader={true} hideChatBot={true} noindex={true}>
  <main class="dd-page">
    <div class="dd-shell dd-fade-in">
      <p class="dd-eyebrow">Demo Day</p>
      <h1 class="dd-title" id="dd-scan-title">Reading.</h1>
      <p class="dd-sub" id="dd-scan-sub">One sec.</p>
      <p class="dd-msg" id="dd-scan-msg"></p>
      <a class="dd-btn dd-btn--ghost" href="/demoday/play" style="margin-top:24px;display:inline-block;text-align:center;text-decoration:none;width:auto;padding-left:32px;padding-right:32px;">Back to the hunt</a>
    </div>
  </main>

  <script>
    import { supabase } from '../../lib/supabase';
    import { stationByToken } from '../../lib/demoday';
    const sb = supabase as any;

    document.addEventListener('astro:page-load', async () => {
      const titleEl = document.getElementById('dd-scan-title') as HTMLHeadingElement;
      const subEl = document.getElementById('dd-scan-sub') as HTMLParagraphElement;
      const msgEl = document.getElementById('dd-scan-msg') as HTMLParagraphElement;

      const params = new URLSearchParams(window.location.search);
      const token = params.get('s');
      const playerId = localStorage.getItem('dd_player_id');

      if (!token) {
        titleEl.textContent = 'No code.';
        subEl.textContent = 'This QR is not part of the hunt.';
        return;
      }

      const found = stationByToken(token);
      if (!found) {
        titleEl.textContent = 'Not a booth.';
        subEl.textContent = 'This code does not match any of the sixteen.';
        return;
      }

      if (!playerId) {
        titleEl.textContent = 'Sign up first.';
        subEl.textContent = 'Drop by the info booth to register, then come back.';
        setTimeout(() => { window.location.href = '/demoday/'; }, 1500);
        return;
      }

      const { data, error } = await sb.rpc('demoday_record_scan', {
        p_player_id: playerId,
        p_station_slug: found.station.slug,
      });

      if (error) {
        titleEl.textContent = 'Something went wrong.';
        subEl.textContent = 'Scan again, or grab a club member.';
        msgEl.textContent = error.message;
        msgEl.className = 'dd-msg dd-msg--err';
        return;
      }

      const result = data as { ok: boolean; reason: string; new_step: number; finished: boolean } | null;
      if (!result) {
        titleEl.textContent = 'No response.';
        subEl.textContent = 'Try once more.';
        return;
      }

      if (result.ok && result.finished) {
        window.location.href = '/demoday/finish';
        return;
      }
      if (result.ok) {
        window.location.href = '/demoday/play?after=ok';
        return;
      }
      if (result.reason === 'already') {
        window.location.href = '/demoday/play?after=already';
        return;
      }
      if (result.reason === 'finished_already') {
        window.location.href = '/demoday/finish';
        return;
      }
      if (result.reason === 'unknown_station') {
        window.location.href = '/demoday/play?after=unknown';
        return;
      }
      titleEl.textContent = 'Could not save that scan.';
      subEl.textContent = result.reason;
    });
  </script>
</AppLayout>
