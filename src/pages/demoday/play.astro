---
import AppLayout from '../../layouts/AppLayout.astro';
import { TOTAL_STATIONS } from '../../lib/demoday';
import '../../styles/demoday.css';
---

<AppLayout title="Demo Day" hideHeader={true} hideChatBot={true} noindex={true}>
  <main class="dd-page">
    <div class="dd-shell dd-stagger">
      <p class="dd-eyebrow">Demo Day</p>

      <div class="dd-progress">
        <div>
          <span class="dd-progress-num" id="dd-step-num">0</span>
          <span class="dd-progress-of"> of {TOTAL_STATIONS}</span>
        </div>
        <a class="dd-link" href="/demoday/leaderboard">Leaderboard</a>
      </div>
      <div class="dd-bar"><div class="dd-bar-fill" id="dd-bar-fill"></div></div>

      <p class="dd-sub" style="margin-bottom:8px;">Scan every booth. Order does not matter. First to scan all 18 wins.</p>
      <p class="dd-presence" id="dd-presence" aria-live="polite"></p>

      <div class="dd-reveal">
        <canvas class="dd-reveal-canvas" id="dd-reveal-canvas"></canvas>
        <p class="dd-reveal-hint">Drag to rotate.</p>
      </div>

      <p class="dd-msg" id="dd-msg" style="margin-top:24px;"></p>

      <ul class="dd-stations" id="dd-stations"></ul>

      <div class="dd-section-rule"></div>
      <button class="dd-btn dd-btn--ghost" id="dd-reset">Sign out of this device</button>
    </div>
  </main>

  <style>
    .dd-reveal {
      margin-top: 36px;
      aspect-ratio: 1;
      width: 100%;
      border: 1px solid var(--dd-line);
      border-radius: 14px;
      background: var(--dd-bg-card);
      position: relative;
      overflow: hidden;
      touch-action: none;
    }
    .dd-reveal-canvas { width: 100%; height: 100%; display: block; cursor: grab; }
    .dd-reveal-canvas:active { cursor: grabbing; }
    .dd-reveal-hint {
      position: absolute;
      bottom: 12px; left: 0; right: 0;
      text-align: center;
      font-size: 11px;
      color: var(--dd-mute);
      margin: 0;
      pointer-events: none;
      letter-spacing: 0.04em;
    }
    .dd-presence {
      font-size: 12px;
      color: var(--dd-mute);
      margin: 14px 0 0;
      opacity: 0;
      transition: opacity 700ms ease;
    }
    .dd-presence.is-ready { opacity: 1; }
    .dd-presence-dot {
      display: inline-block;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #c8e3c4;
      margin-right: 8px;
      vertical-align: 1px;
      animation: dd-pulse 1800ms ease-in-out infinite;
    }
    @keyframes dd-pulse {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }
    .dd-stations {
      list-style: none;
      padding: 0;
      margin: 32px 0 0;
    }
    .dd-station {
      display: flex;
      align-items: flex-start;
      padding: 14px 0;
      border-bottom: 1px solid var(--dd-line);
      gap: 14px;
      transition: opacity 320ms ease;
    }
    .dd-station:last-child { border-bottom: none; }
    .dd-station-check {
      width: 18px;
      flex-shrink: 0;
      font-size: 13px;
      color: var(--dd-faint);
      line-height: 1.5;
      font-variant-numeric: tabular-nums;
    }
    .dd-station.is-done .dd-station-check { color: var(--dd-fg); }
    .dd-station-text { flex: 1; min-width: 0; }
    .dd-station-name {
      font-size: 15px;
      font-weight: 500;
      letter-spacing: -0.01em;
    }
    .dd-station-desc {
      font-size: 13px;
      color: var(--dd-mute);
      margin-top: 2px;
      line-height: 1.45;
    }
    .dd-station.is-done .dd-station-name { opacity: 0.45; }
    .dd-station.is-done .dd-station-desc { opacity: 0.45; }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';
    import { STATIONS, TOTAL_STATIONS } from '../../lib/demoday';
    import { playScanChime, playWrongTone, playSoftTap, primeAudio } from '../../lib/demoday-sound';
    import { RevealScene } from '../../lib/demoday-reveal';
    const sb = supabase as any;

    function escapeHTML(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
    }

    function renderStations(listEl: HTMLElement, scanned: Set<string>): void {
      const sorted = [...STATIONS].sort((a, b) => a.name.localeCompare(b.name));
      listEl.innerHTML = sorted.map((s) => {
        const done = scanned.has(s.slug);
        return `<li class="dd-station${done ? ' is-done' : ''}">
          <span class="dd-station-check">${done ? '✓' : '·'}</span>
          <div class="dd-station-text">
            <div class="dd-station-name">${escapeHTML(s.name)}</div>
            <div class="dd-station-desc">${escapeHTML(s.description)}</div>
          </div>
        </li>`;
      }).join('');
    }

    async function refreshPresence(presenceEl: HTMLElement): Promise<void> {
      const startOfToday = new Date();
      startOfToday.setHours(0, 0, 0, 0);
      const since = startOfToday.toISOString();
      const [hRes, fRes] = await Promise.all([
        sb.from('demoday_players')
          .select('id', { count: 'exact', head: true })
          .gte('started_at', since)
          .is('completed_at', null),
        sb.from('demoday_players')
          .select('id', { count: 'exact', head: true })
          .not('completed_at', 'is', null)
          .gte('started_at', since),
      ]);
      const hunting = hRes.count ?? 0;
      const finished = fRes.count ?? 0;
      const huntWord = hunting === 1 ? 'person' : 'people';
      presenceEl.innerHTML = `<span class="dd-presence-dot"></span>${hunting} ${huntWord} hunting · ${finished} finished today`;
      presenceEl.classList.add('is-ready');
    }

    document.addEventListener('astro:page-load', async () => {
      const playerId = localStorage.getItem('dd_player_id');
      const stepNum = document.getElementById('dd-step-num') as HTMLSpanElement;
      const barFill = document.getElementById('dd-bar-fill') as HTMLDivElement;
      const msg = document.getElementById('dd-msg') as HTMLParagraphElement;
      const presenceEl = document.getElementById('dd-presence') as HTMLParagraphElement;
      const stationsList = document.getElementById('dd-stations') as HTMLUListElement;
      const resetBtn = document.getElementById('dd-reset') as HTMLButtonElement;

      if (!playerId) {
        window.location.href = '/demoday/';
        return;
      }

      const resp = await sb
        .from('demoday_players')
        .select('id, name, current_step, completed_at')
        .eq('id', playerId)
        .maybeSingle();
      const player = resp.data as { id: string; name: string; current_step: number; completed_at: string | null } | null;

      if (resp.error || !player) {
        localStorage.removeItem('dd_player_id');
        window.location.href = '/demoday/';
        return;
      }

      if (player.completed_at) {
        window.location.href = '/demoday/finish';
        return;
      }

      const scansResp = await sb
        .from('demoday_scans')
        .select('station_slug')
        .eq('player_id', playerId);
      const scanned = new Set<string>(((scansResp.data ?? []) as { station_slug: string }[]).map((r) => r.station_slug));
      renderStations(stationsList, scanned);

      const step = player.current_step ?? 0;
      stepNum.textContent = String(step);
      barFill.style.width = `${(step / TOTAL_STATIONS) * 100}%`;

      const canvas = document.getElementById('dd-reveal-canvas') as HTMLCanvasElement;
      const reveal = new RevealScene(canvas, { totalGroups: TOTAL_STATIONS, initialRevealed: step });
      document.addEventListener('astro:before-preparation', () => reveal.dispose(), { once: true });

      const params = new URLSearchParams(window.location.search);
      const after = params.get('after');
      if (after === 'ok') {
        msg.textContent = 'Scanned. Keep going.';
        msg.className = 'dd-msg dd-msg--ok';
        playScanChime(step);
      } else if (after === 'unknown') {
        msg.textContent = 'That QR is not part of the hunt.';
        msg.className = 'dd-msg dd-msg--err';
        playWrongTone();
      } else if (after === 'already') {
        msg.textContent = 'Already scanned this one.';
        msg.className = 'dd-msg';
        playSoftTap();
      }

      const onFirstTouch = () => {
        primeAudio();
        document.removeEventListener('click', onFirstTouch);
        document.removeEventListener('touchstart', onFirstTouch);
      };
      document.addEventListener('click', onFirstTouch);
      document.addEventListener('touchstart', onFirstTouch);

      void refreshPresence(presenceEl);
      const presenceTimer = window.setInterval(() => void refreshPresence(presenceEl), 20000);
      document.addEventListener('astro:before-preparation', () => clearInterval(presenceTimer), { once: true });

      resetBtn.addEventListener('click', () => {
        if (!confirm('Sign out on this device? Your progress on the server stays.')) return;
        localStorage.removeItem('dd_player_id');
        window.location.href = '/demoday/';
      });
    });
  </script>
</AppLayout>
