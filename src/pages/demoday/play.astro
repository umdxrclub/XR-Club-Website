---
import AppLayout from '../../layouts/AppLayout.astro';
import { TOTAL_STATIONS } from '../../lib/demoday';
import '../../styles/demoday.css';
---

<AppLayout title="Demo Day" hideHeader={true} hideChatBot={true} noindex={true}>
  <main class="dd-page">
    <div class="dd-shell dd-stagger">
      <p class="dd-eyebrow">Demo Day</p>

      <div class="dd-progress">
        <div>
          <span class="dd-progress-num" id="dd-step-num">0</span>
          <span class="dd-progress-of"> of {TOTAL_STATIONS}</span>
        </div>
        <div style="display:flex;gap:18px;">
          <a class="dd-link" href="/demoday/vote">Vote</a>
          <a class="dd-link" href="/demoday/leaderboard">Leaderboard</a>
        </div>
      </div>
      <div class="dd-bar"><div class="dd-bar-fill" id="dd-bar-fill"></div></div>

      <p class="dd-sub" style="margin-bottom:8px;">Scan every booth. Order does not matter. First to scan every project wins!</p>
      <p class="dd-presence" id="dd-presence" aria-live="polite"></p>

      <div class="dd-reveal" id="dd-reveal"></div>

      <button class="dd-btn" id="dd-scan-btn" style="margin-top:24px;">Scan a booth</button>
      <p class="dd-msg" id="dd-msg" style="margin-top:18px;"></p>

      <section class="dd-collected" id="dd-collected" hidden>
        <p class="dd-eyebrow" style="margin-top:48px;margin-bottom:16px;">Collected</p>
        <ul class="dd-collected-list" id="dd-collected-list"></ul>
      </section>

      <div class="dd-section-rule"></div>
      <a class="dd-btn dd-btn--ghost" href="/demoday/vote" style="display:block;text-align:center;text-decoration:none;margin-bottom:14px;">Pick your top three</a>
      <button class="dd-btn dd-btn--ghost" id="dd-reset">Sign out of this device</button>
    </div>
  </main>

  <div class="dd-scanner" id="dd-scanner" hidden>
    <video class="dd-scanner-video" id="dd-scanner-video" playsinline muted></video>
    <div class="dd-scanner-overlay">
      <div class="dd-scanner-frame">
        <span class="dd-scanner-corner dd-scanner-corner--tl"></span>
        <span class="dd-scanner-corner dd-scanner-corner--tr"></span>
        <span class="dd-scanner-corner dd-scanner-corner--bl"></span>
        <span class="dd-scanner-corner dd-scanner-corner--br"></span>
      </div>
      <p class="dd-scanner-status" id="dd-scanner-status">Point at a booth's QR code.</p>
      <button class="dd-scanner-close" id="dd-scanner-close">Cancel</button>
    </div>
  </div>

  <style>
    .dd-reveal {
      margin-top: 36px;
      width: 100%;
      aspect-ratio: 1;
      position: relative;
    }
    .dd-puzzle-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    .dd-piece {
      transition: opacity 900ms ease;
    }
    .dd-presence {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--dd-fg);
      margin: 18px 0 0;
      opacity: 0;
      transition: opacity 700ms ease;
    }
    .dd-presence.is-ready { opacity: 1; }
    .dd-presence-suffix {
      font-size: 14px;
      font-weight: 400;
      color: var(--dd-mute);
      margin-left: 6px;
    }
    .dd-scanner {
      position: fixed;
      inset: 0;
      background: #000;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: dd-fade-in 280ms ease;
    }
    .dd-scanner[hidden] { display: none; }
    .dd-scanner-video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: #000;
    }
    .dd-scanner-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .dd-scanner-frame {
      position: relative;
      width: min(70vmin, 320px);
      height: min(70vmin, 320px);
      border-radius: 24px;
      box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.5);
    }
    .dd-scanner-corner {
      position: absolute;
      width: 28px;
      height: 28px;
      border-color: rgba(245, 239, 213, 0.95);
      border-style: solid;
      border-width: 0;
    }
    .dd-scanner-corner--tl { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; border-top-left-radius: 18px; }
    .dd-scanner-corner--tr { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; border-top-right-radius: 18px; }
    .dd-scanner-corner--bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; border-bottom-left-radius: 18px; }
    .dd-scanner-corner--br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; border-bottom-right-radius: 18px; }
    .dd-scanner-status {
      position: absolute;
      bottom: max(48px, env(safe-area-inset-bottom));
      left: 0; right: 0;
      text-align: center;
      color: rgba(245, 239, 213, 0.85);
      font-size: 14px;
      letter-spacing: -0.005em;
      margin: 0;
    }
    .dd-scanner-close {
      position: absolute;
      top: max(20px, env(safe-area-inset-top));
      right: 20px;
      pointer-events: auto;
      background: rgba(245, 239, 213, 0.12);
      color: var(--dd-fg);
      border: none;
      border-radius: 999px;
      padding: 10px 18px;
      font-family: inherit;
      font-size: 14px;
      cursor: pointer;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .dd-collected-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .dd-collected-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 14px 14px 16px;
      border: 1px solid var(--dd-line-strong);
      border-radius: 12px;
      margin-bottom: 8px;
      font-size: 15px;
      font-weight: 500;
      letter-spacing: -0.01em;
      background: rgba(245, 239, 213, 0.04);
      animation: dd-slide-up 600ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    }
    .dd-collected-check {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--dd-fg);
      color: var(--dd-bg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';
    import { STATIONS, TOTAL_STATIONS } from '../../lib/demoday';
    import { playScanChime, playWrongTone, playSoftTap, primeAudio } from '../../lib/demoday-sound';
    import { PuzzleReveal } from '../../lib/demoday-puzzle';
    import { DemoDayScanner, extractTokenFromQR } from '../../lib/demoday-scanner';
    const sb = supabase as any;

    function escapeHTML(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
    }

    function renderCollected(section: HTMLElement, listEl: HTMLElement, scannedInOrder: string[]): void {
      if (scannedInOrder.length === 0) {
        section.setAttribute('hidden', '');
        listEl.innerHTML = '';
        return;
      }
      section.removeAttribute('hidden');
      const lookup = new Map(STATIONS.map((s) => [s.slug, s]));
      listEl.innerHTML = scannedInOrder
        .map((slug) => lookup.get(slug))
        .filter((s): s is typeof STATIONS[number] => Boolean(s))
        .map((s) => `<li class="dd-collected-item"><span>${escapeHTML(s.name)}</span><span class="dd-collected-check">✓</span></li>`)
        .join('');
    }

    async function refreshPresence(presenceEl: HTMLElement): Promise<void> {
      const startOfToday = new Date();
      startOfToday.setHours(0, 0, 0, 0);
      const since = startOfToday.toISOString();
      const hRes = await sb.from('demoday_players')
        .select('id', { count: 'exact', head: true })
        .gte('started_at', since)
        .is('completed_at', null);
      const hunting = hRes.count ?? 0;
      const huntWord = hunting === 1 ? 'person hunting' : 'people hunting';
      presenceEl.innerHTML = `${hunting}<span class="dd-presence-suffix">${huntWord}</span>`;
      presenceEl.classList.add('is-ready');
    }

    document.addEventListener('astro:page-load', async () => {
      const playerId = localStorage.getItem('dd_player_id');
      const stepNum = document.getElementById('dd-step-num') as HTMLSpanElement;
      const barFill = document.getElementById('dd-bar-fill') as HTMLDivElement;
      const msg = document.getElementById('dd-msg') as HTMLParagraphElement;
      const presenceEl = document.getElementById('dd-presence') as HTMLParagraphElement;
      const collectedSection = document.getElementById('dd-collected') as HTMLElement;
      const collectedList = document.getElementById('dd-collected-list') as HTMLUListElement;
      const resetBtn = document.getElementById('dd-reset') as HTMLButtonElement;
      const revealEl = document.getElementById('dd-reveal') as HTMLDivElement;

      if (!playerId) {
        window.location.href = '/demoday/';
        return;
      }

      let reveal: PuzzleReveal | null = null;

      async function refreshGame(): Promise<{ step: number; finished: boolean } | null> {
        const resp = await sb
          .from('demoday_players')
          .select('id, name, current_step, completed_at')
          .eq('id', playerId)
          .maybeSingle();
        const player = resp.data as { id: string; name: string; current_step: number; completed_at: string | null } | null;

        if (resp.error || !player) {
          localStorage.removeItem('dd_player_id');
          window.location.href = '/demoday/';
          return null;
        }
        if (player.completed_at) {
          window.location.href = '/demoday/finish';
          return { step: player.current_step ?? 0, finished: true };
        }

        const step = player.current_step ?? 0;
        stepNum.textContent = String(step);
        barFill.style.width = `${(step / TOTAL_STATIONS) * 100}%`;

        const scansResp = await sb
          .from('demoday_scans')
          .select('station_slug, scanned_at')
          .eq('player_id', playerId)
          .order('scanned_at', { ascending: false });
        const scannedRows = (scansResp.data ?? []) as { station_slug: string; scanned_at: string }[];
        renderCollected(collectedSection, collectedList, scannedRows.map((r) => r.station_slug));

        if (!reveal) {
          reveal = new PuzzleReveal(revealEl, {
            imageUrl: '/Images/puzzleboy.png',
            totalPieces: TOTAL_STATIONS,
            initialRevealed: step,
            seedKey: playerId as string,
          });
        } else {
          reveal.setRevealed(step);
        }

        return { step, finished: false };
      }

      const initial = await refreshGame();
      if (!initial) return;

      document.addEventListener('astro:before-preparation', () => { reveal?.dispose(); reveal = null; }, { once: true });

      const params = new URLSearchParams(window.location.search);
      const after = params.get('after');
      if (after === 'ok') {
        msg.textContent = 'Scanned. Keep going.';
        msg.className = 'dd-msg dd-msg--ok';
        playScanChime(initial.step);
      } else if (after === 'unknown') {
        msg.textContent = 'That QR is not part of the hunt.';
        msg.className = 'dd-msg dd-msg--err';
        playWrongTone();
      } else if (after === 'already') {
        msg.textContent = 'Already scanned this one.';
        msg.className = 'dd-msg';
        playSoftTap();
      }

      const onFirstTouch = () => {
        primeAudio();
        document.removeEventListener('click', onFirstTouch);
        document.removeEventListener('touchstart', onFirstTouch);
      };
      document.addEventListener('click', onFirstTouch);
      document.addEventListener('touchstart', onFirstTouch);

      void refreshPresence(presenceEl);
      const presenceTimer = window.setInterval(() => void refreshPresence(presenceEl), 20000);
      document.addEventListener('astro:before-preparation', () => clearInterval(presenceTimer), { once: true });

      resetBtn.addEventListener('click', () => {
        if (!confirm('Sign out on this device? Your progress on the server stays.')) return;
        localStorage.removeItem('dd_player_id');
        window.location.href = '/demoday/';
      });

      const scanBtn = document.getElementById('dd-scan-btn') as HTMLButtonElement;
      const scannerEl = document.getElementById('dd-scanner') as HTMLDivElement;
      const scannerVideo = document.getElementById('dd-scanner-video') as HTMLVideoElement;
      const scannerStatus = document.getElementById('dd-scanner-status') as HTMLParagraphElement;
      const scannerClose = document.getElementById('dd-scanner-close') as HTMLButtonElement;
      let activeScanner: DemoDayScanner | null = null;

      function closeScanner(): void {
        activeScanner?.stop();
        activeScanner = null;
        scannerEl.setAttribute('hidden', '');
      }

      async function handleQRText(text: string): Promise<void> {
        const token = extractTokenFromQR(text);
        if (!token) {
          scannerStatus.textContent = 'That QR is not part of the hunt.';
          setTimeout(closeScanner, 900);
          playWrongTone();
          return;
        }
        const station = STATIONS.find((s) => s.token === token);
        if (!station) {
          scannerStatus.textContent = 'That QR is not part of the hunt.';
          setTimeout(closeScanner, 900);
          playWrongTone();
          return;
        }
        scannerStatus.textContent = `${station.name}…`;
        const { data, error } = await sb.rpc('demoday_record_scan', {
          p_player_id: playerId,
          p_station_slug: station.slug,
        });
        if (error) {
          scannerStatus.textContent = error.message || 'Could not save that scan.';
          setTimeout(closeScanner, 1500);
          return;
        }
        const result = data as { ok: boolean; reason: string; finished: boolean } | null;
        if (result?.ok && result.finished) {
          closeScanner();
          window.location.href = '/demoday/finish';
          return;
        }
        if (result?.ok) {
          closeScanner();
          const state = await refreshGame();
          if (state) {
            playScanChime(state.step);
            msg.textContent = `${station.name} scanned. ${TOTAL_STATIONS - state.step} to go.`;
            msg.className = 'dd-msg dd-msg--ok';
          }
          return;
        }
        if (result?.reason === 'already') {
          closeScanner();
          msg.textContent = 'Already scanned this one.';
          msg.className = 'dd-msg';
          playSoftTap();
          return;
        }
        scannerStatus.textContent = result?.reason || 'Could not save that scan.';
        setTimeout(closeScanner, 1500);
      }

      scanBtn.addEventListener('click', async () => {
        primeAudio();
        scannerEl.removeAttribute('hidden');
        scannerStatus.textContent = 'Point at a booth\'s QR code.';
        activeScanner = new DemoDayScanner(scannerVideo, {
          onDetect: (text) => { void handleQRText(text); },
          onError: (e) => {
            scannerStatus.textContent = e.message || 'Could not open the camera.';
          },
        });
        await activeScanner.start();
      });

      scannerClose.addEventListener('click', closeScanner);
      document.addEventListener('astro:before-preparation', closeScanner, { once: true });
    });
  </script>
</AppLayout>
