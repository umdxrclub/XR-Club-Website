---
import AppLayout from '../../layouts/AppLayout.astro';
import '../../styles/demoday.css';
---

<AppLayout title="Demo Day" hideHeader={true} hideChatBot={true} noindex={true}>
  <main class="dd-page">
    <div class="dd-shell dd-stagger">
      <p class="dd-eyebrow">Demo Day</p>
      <h1 class="dd-title">Scavenger hunt.</h1>
      <p class="dd-sub">Scan the QR at every booth. Order does not matter. First to scan all eighteen wins.</p>

      <div class="dd-card">
        <form id="dd-register-form" novalidate>
          <label class="dd-field">
            <span class="dd-label">Full name</span>
            <input class="dd-input" id="dd-name" type="text" autocomplete="name" placeholder="First and last" required />
          </label>
          <button class="dd-btn" type="submit" id="dd-start-btn">Start</button>
          <p class="dd-msg" id="dd-msg"></p>
        </form>
      </div>

      <p class="dd-presence" id="dd-presence" aria-live="polite"></p>

      <div class="dd-section-rule"></div>
      <p class="dd-sub" style="margin-bottom:0;">Already playing? <a class="dd-link" href="/demoday/play">Pick up where you left off</a>. Or see the <a class="dd-link" href="/demoday/leaderboard">leaderboard</a>.</p>
    </div>
  </main>

  <style>
    .dd-presence {
      font-size: 12px;
      color: var(--dd-mute);
      margin: 24px 0 0;
      opacity: 0;
      transition: opacity 700ms ease;
    }
    .dd-presence.is-ready { opacity: 1; }
    .dd-presence-dot {
      display: inline-block;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #c8e3c4;
      margin-right: 8px;
      vertical-align: 1px;
      animation: dd-pulse 1800ms ease-in-out infinite;
    }
    @keyframes dd-pulse {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';
    const sb = supabase as any;

    async function refreshPresence(presenceEl: HTMLElement): Promise<void> {
      const startOfToday = new Date();
      startOfToday.setHours(0, 0, 0, 0);
      const since = startOfToday.toISOString();
      const [hRes, fRes] = await Promise.all([
        sb.from('demoday_players')
          .select('id', { count: 'exact', head: true })
          .gte('started_at', since)
          .is('completed_at', null),
        sb.from('demoday_players')
          .select('id', { count: 'exact', head: true })
          .not('completed_at', 'is', null)
          .gte('started_at', since),
      ]);
      const hunting = hRes.count ?? 0;
      const finished = fRes.count ?? 0;
      const huntWord = hunting === 1 ? 'person' : 'people';
      presenceEl.innerHTML = `<span class="dd-presence-dot"></span>${hunting} ${huntWord} hunting · ${finished} finished today`;
      presenceEl.classList.add('is-ready');
    }

    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('dd-register-form') as HTMLFormElement | null;
      if (!form) return;

      const nameInput = document.getElementById('dd-name') as HTMLInputElement;
      const btn = document.getElementById('dd-start-btn') as HTMLButtonElement;
      const msg = document.getElementById('dd-msg') as HTMLParagraphElement;
      const presenceEl = document.getElementById('dd-presence') as HTMLParagraphElement;

      void refreshPresence(presenceEl);
      const presenceTimer = window.setInterval(() => void refreshPresence(presenceEl), 20000);
      document.addEventListener('astro:before-preparation', () => clearInterval(presenceTimer), { once: true });

      const existing = localStorage.getItem('dd_player_id');
      if (existing) {
        msg.textContent = 'Picking up where you left off.';
        msg.className = 'dd-msg';
        setTimeout(() => { window.location.href = '/demoday/play'; }, 500);
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = nameInput.value.trim();
        if (name.length < 2 || !name.includes(' ')) {
          msg.textContent = 'First and last name, please.';
          msg.className = 'dd-msg dd-msg--err';
          return;
        }

        btn.disabled = true;
        msg.textContent = '';
        msg.className = 'dd-msg';

        const insertResp = await sb
          .from('demoday_players')
          .insert({ name })
          .select('id')
          .single();
        const inserted = insertResp.data as { id: string } | null;
        if (insertResp.error || !inserted) {
          const err = insertResp.error?.message || 'Unknown error';
          msg.textContent = err;
          msg.className = 'dd-msg dd-msg--err';
          btn.disabled = false;
          console.error('demoday register failed', insertResp.error);
          return;
        }

        localStorage.setItem('dd_player_id', inserted.id);
        window.location.href = '/demoday/play';
      });
    });
  </script>
</AppLayout>
